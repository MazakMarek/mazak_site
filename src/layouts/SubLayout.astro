---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  active: string;
}
const { title, active } = Astro.props;
---
<Layout title={`${title} — Marek Mazák`}>
  <Nav active={active} />
  <main>
    <slot />
  </main>
  <Footer />
</Layout>

<style is:global>
  main { min-height: calc(100vh - 49px - 49px); }
</style>
