---
const jobs = [
  {
    title: "Automated Software Tester",
    company: "Scheidt & Bachmann",
    location: "Žilina, SR",
    period: "Júl 2025 – súčasnosť",
    current: true,
    items: [
      "Návrh a implementácia automatizovaných testovacích skriptov",
      "Analýza a validácia datasetov pre projekty strojového učenia",
      
    ],
  },
  {
    title: "Software Tester",
    company: "Gratex IQ, a.s.",
    location: "Žilina, SR",
    period: "Október 2023 – Jún 2025",
    current: false,
    items: [
      "Manuálne aj automatizované testovanie (SoapUI, Robot Framework)",
      "Príprava UAT testov, testovacích scenárov a overovanie požiadaviek",
      "Spolupráca s vývojármi pri lokalizácii a odstraňovaní chýb",
    ],
  },
  {
    title: "Fakultná prax — kontrola dát pre ML",
    company: "FRI / Scheidt & Bachmann",
    location: "Žilina, SR",
    period: "November 2024 – Január 2025",
    current: false,
    items: ["Analýza a kontrola datasetov pre projekty strojového učenia"],
  },
  {
    title: "Pomocný pracovník / Pokladňa",
    company: "Hornbach – Baumarkt SK",
    location: "Košice, SR",
    period: "November 2018 – December 2023",
    current: false,
    items: ["Obsluha zákazníkov a práca za pokladňou"],
  },
];
---

<section class="section" id="skusenosti">
  <div class="section-inner">
    <div class="section-head">
      <p class="section-label">01</p>
      <h2 class="section-title">Pracovné skúsenosti</h2>
    </div>

    <div class="jobs">
      {jobs.map((job) => (
        <div class={`job ${job.current ? "job--current" : ""}`}>
          <div class="job-left">
            <span class={`job-dot ${job.current ? "job-dot--current" : ""}`}></span>
            <span class="job-period">{job.period}</span>
          </div>
          <div class="job-right">
            <div class="job-header">
              <div>
                <h3 class="job-title">{job.title}</h3>
                <p class="job-company">{job.company} <span>· {job.location}</span></p>
              </div>
              {job.current && <span class="job-badge">Aktuálne</span>}
            </div>
            {job.items.length > 0 && (
              <ul class="job-items">
                {job.items.map((item) => <li>{item}</li>)}
              </ul>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section {
    border-bottom: 1px solid var(--border-muted);
    padding: 3.5rem 2.5rem;
  }
  .section-inner { max-width: 860px; }

  .section-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 2.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-muted);
  }
  .section-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    font-family: var(--font-body);
  }
  .section-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .jobs { display: flex; flex-direction: column; gap: 0; }

  .job {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border-muted);
    align-items: start;
  }
  .job:last-child { border-bottom: none; }

  .job-left {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.15rem;
  }
  .job-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--border);
    display: block;
  }
  .job-dot--current { background: var(--orange); box-shadow: 0 0 8px rgba(240,136,62,0.4); }

  .job-period {
    font-size: 0.72rem;
    color: var(--text-muted);
    font-weight: 400;
    line-height: 1.4;
  }

  .job-right { flex: 1; }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.6rem;
  }
  .job-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.2rem;
  }
  .job-company {
    font-size: 0.78rem;
    color: var(--text-secondary);
  }
  .job-company span { color: var(--text-muted); }

  .job-badge {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--orange);
    background: rgba(240,136,62,0.1);
    border: 1px solid rgba(240,136,62,0.25);
    padding: 0.18rem 0.55rem;
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .job-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .job-items li {
    font-size: 0.8rem;
    color: var(--text-secondary);
    padding-left: 0.875rem;
    position: relative;
    line-height: 1.5;
  }
  .job-items li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .job { grid-template-columns: 1fr; gap: 0.75rem; }
    .job-left { flex-direction: row; align-items: center; gap: 0.75rem; }
  }
</style>
