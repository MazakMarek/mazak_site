---
const jobs = [
  {
    title: "Automated Software Tester",
    company: "Scheidt & Bachmann",
    location: "Žilina, SR",
    period: "Júl 2025 – súčasnosť",
    current: true,
    items: [
      "Návrh a implementácia automatizovaných testovacích skriptov",
      "Analýza a validácia datasetov pre strojové učenie",
      "Spolupráca v medzinárodnom vývojovom tíme",
    ],
  },
  {
    title: "Software Tester",
    company: "Gratex IQ, a.s.",
    location: "Žilina, SR",
    period: "Október 2023 – Jún 2025",
    current: false,
    items: [
      "Manuálne aj automatizované testovanie (SoapUI, Robot Framework)",
      "Príprava UAT testov a testovacích scenárov",
      "Spolupráca s vývojármi pri lokalizácii a odstraňovaní chýb",
    ],
  },
  {
    title: "Fakultná prax — kontrola dát pre ML",
    company: "FRI / Scheidt & Bachmann",
    location: "Žilina, SR",
    period: "November 2024 – Január 2025",
    current: false,
    items: [
      "Analýza a kontrola datasetov pre projekty strojového učenia",
    ],
  },
  {
    title: "Pomocný pracovník / Pokladňa",
    company: "Hornbach – Baumarkt SK",
    location: "Košice, SR",
    period: "November 2018 – December 2023",
    current: false,
    items: [
      "Obsluha zákazníkov a práca za pokladňou",
    ],
  },
  {
    title: "Barman",
    company: "Restaurant Il Gusto",
    location: "Kitzbühel, Rakúsko",
    period: "Jún 2022 – August 2022",
    current: false,
    items: [
      "Miešanie nápojov, obsluha zákazníkov, vedenie zásob",
    ],
  },
];
---

<section class="section">
  <div class="section-inner">
    <h2 class="section-title">
      <span class="title-label">Pracovné skúsenosti</span>
    </h2>
    <div class="timeline">
      {jobs.map((job) => (
        <div class={`job ${job.current ? 'job--current' : ''}`}>
          <div class="job-dot"></div>
          <div class="job-content">
            <div class="job-header">
              <div>
                <h3 class="job-title">{job.title}</h3>
                <p class="job-company">
                  {job.company}
                  <span class="job-location">· {job.location}</span>
                </p>
              </div>
              <span class={`job-period ${job.current ? 'job-period--current' : ''}`}>
                {job.period}
              </span>
            </div>
            {job.items.length > 0 && (
              <ul class="job-items">
                {job.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section {
    padding: 4rem 2rem;
    border-bottom: 1px solid var(--border);
  }

  .section-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 2.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .title-label {
    white-space: nowrap;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--border);
  }

  .job {
    position: relative;
    padding-bottom: 2.25rem;
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .job:last-child {
    padding-bottom: 0;
  }

  .job-dot {
    position: absolute;
    left: -2rem;
    top: 5px;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--border);
    flex-shrink: 0;
    transition: border-color 0.2s;
  }

  .job--current .job-dot {
    background: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-dim);
  }

  .job-content {
    flex: 1;
  }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.65rem;
    flex-wrap: wrap;
  }

  .job-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 0.2rem;
  }

  .job-company {
    font-size: 0.9rem;
    color: var(--muted);
    font-weight: 400;
  }

  .job-location {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .job-period {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--muted);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.2rem 0.65rem;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .job-period--current {
    color: var(--accent);
    background: var(--accent-dim);
    border-color: var(--accent);
  }

  .job-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .job-items li {
    font-size: 0.9rem;
    color: #3A4D60;
    line-height: 1.55;
    padding-left: 1rem;
    position: relative;
  }

  .job-items li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  @media (max-width: 580px) {
    .job-header {
      flex-direction: column;
    }
    .job-period {
      align-self: flex-start;
    }
  }
</style>
