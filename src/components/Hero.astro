<section class="hero">
  <div class="hero-inner">
    <div class="terminal">
      <div class="terminal-bar">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
        <span class="terminal-title">cv.sh</span>
      </div>
      <div class="terminal-body">
        <p class="line"><span class="prompt">$</span> <span class="cmd">./run-profile</span></p>
        <p class="line output"><span class="check">✓</span> loading <strong>Marek Mazák</strong> <span class="tag">bc.</span></p>
        <p class="line output"><span class="check">✓</span> role: <strong>Automated Software Tester</strong></p>
        <p class="line output"><span class="check">✓</span> location: <strong>Žilina, SR</strong></p>
        <p class="line output"><span class="check">✓</span> status: <span class="pass">all checks passing</span> <span class="blink">▌</span></p>
      </div>
    </div>

    <div class="hero-meta">
      <p class="hero-tagline">
        Testujem softvér, analyzujem dáta a zbieram trofeje z Via Ferrata — detailné myslenie sa hodí všade.
      </p>
      <div class="hero-links">
        <a href="mailto:mazak.marek1@gmail.com" class="link-chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          mazak.marek1@gmail.com
        </a>
        <a href="tel:+421917284276" class="link-chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.5 12.32a19.79 19.79 0 0 1-3-8.59A2 2 0 0 1 3.4 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.4a16 16 0 0 0 6.29 6.29l.76-.76a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          +421 917 284 276
        </a>
      </div>
    </div>
