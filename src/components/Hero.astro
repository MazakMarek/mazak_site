<style>
  .hero {
    background: var(--dark);
    padding: 4rem 2rem 3.5rem;
  }

  .hero-inner {
    max-width: 860px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  /* Terminal */
  .terminal {
    background: #0A1117;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.5);
    font-family: 'Courier New', monospace;
    font-size: 0.875rem;
  }

  .terminal-bar {
    background: #1C2B3A;
    padding: 0.6rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .dot.red    { background: #FF5F57; }
  .dot.yellow { background: #FEBC2E; }
  .dot.green  { background: #28C840; }

  .terminal-title {
    margin-left: auto;
    margin-right: auto;
    color: #4A6274;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }

  .terminal-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .line {
    color: #8BA7BE;
    white-space: nowrap;
  }
  .line.output { color: #C5D8E8; }

  .prompt { color: var(--accent); margin-right: 0.5rem; }
  .cmd    { color: #FFFFFF; }

  .check  { color: var(--accent); margin-right: 0.5rem; }
  .pass   { color: var(--accent); font-weight: 600; }

  .tag {
    background: var(--accent-dim);
    border: 1px solid var(--accent);
    color: var(--accent);
    font-size: 0.7rem;
    padding: 0 0.35rem;
    border-radius: 3px;
    letter-spacing: 0.05em;
    vertical-align: middle;
  }

  .blink {
    color: var(--accent);
    animation: blink 1.1s step-end infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* Right side */
  .hero-tagline {
    color: #A8BECF;
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 1.75rem;
    font-family: var(--font-body);
  }

  .hero-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .link-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #C5D8E8;
    text-decoration: none;
    font-size: 0.85rem;
    font-family: var(--font-body);
    transition: color 0.2s;
  }
  .link-chip:hover { color: var(--accent); }
  .link-chip svg   { flex-shrink: 0; opacity: 0.6; }

  @media (max-width: 680px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .terminal { font-size: 0.78rem; }
    .terminal-body { padding: 1rem 1.1rem 1.2rem; }
    .line { white-space: normal; }
  }
</style>
