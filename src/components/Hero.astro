    </div>

    <div class="hero-nav-cards">
      <a href={`${base}skusenosti/`} class="nav-card">
        Skúsenosti 
      </a>
          <!-- Nav karty  
    Komentar na navigaciu na ostatne stranky
    TODO
      <a href={`${base}znalosti/`} class="nav-card">
        Znalosti 
      </a>-->
      <a href={`${base}vzdelanie/`} class="nav-card">
        Vzdelanie 
      </a>
    </div> 
  </div>
</section>

<div class="contact-bar">
  <div class="contact-item">
    <span class="contact-label">Email</span>
    <a href="mailto:mazak.marek1@gmail.com" class="contact-val">mazak.marek1@gmail.com</a>
  </div>
  <div class="contact-item">
    <span class="contact-label">Tel</span>
    <a href="tel:+421917284276" class="contact-val">+421 917 284 276</a>
  </div>
  <div class="contact-item">
    <span class="contact-label">Lokalita</span>
    <span class="contact-val">Žilina, SR</span>
  </div>
  <div class="status-pill">
    <span class="status-dot"></span>
    Aktívne zamestnaný
  </div>
</div>

<style>
  .hero {
    display: grid;
    grid-template-columns: 52% 48%;
    min-height: 0;
    height: calc(100vh - 62px - 51px); 
    border-bottom: 1px solid var(--border-muted);
    margin-top: 0;
  }

  /* ── LEFT ── */
  .hero-left {
    border-right: 1px solid var(--border-muted);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
  }

  .name-block {
    padding: 0 2rem 0 2rem;
    flex: 1;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.75rem;
  }

  .avatar {
    width: 170px;
    height: 170px;
    border-radius: 50%;
    border: 2px solid var(--border);
    background: var(--bg-elevated);
    flex-shrink: 0;
    overflow: hidden;
    align-self: center;
  }

  .avatar-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .name-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .name-row {
    font-family: var(--font-display);
    font-size: clamp(4rem, 6vw, 7.5rem);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.03em;
    white-space: nowrap;
  }
  .n-bright { color: var(--text-primary); }
  .n-ghost  { color: var(--name-ghost); }

  .stats-card {
    background: var(--bg-stats);
    border-top: 1px solid var(--border-muted);
    padding: 1.5rem 2rem;
  }

  .stats-row {
    display: flex;
    align-items: center;
    justify-content: space-evenly;
  }

  .stat-sep {
    width: 1px;
    height: 2.5rem;
    background: var(--border-muted);
    flex-shrink: 0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }
  .stat-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--orange);
    line-height: 1;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .stat-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ── RIGHT ── */
  .hero-right {
    padding: 1rem 2.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    justify-content: center;
    overflow-y: auto;
  }

  .bio-text {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.7;
    font-weight: 400;
  }

  .divider {
    height: 1px;
    background: var(--border-muted);
    flex-shrink: 0;
  }

  .info-block {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .info-label {
    font-size: 0.5rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.15rem;
  }

  .info-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .info-sub {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }
  .info-thesis {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-weight: 700;
  }

  .progress-bar {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  margin-top: 0.4rem;
}

.progress-track {
  width: 200px;
  height: 6px;
  background: var(--border-muted);
  border-radius: 2px;
}

.progress-fill {
  height: 100%;
  width: 90%;
  background: var(--orange);
  border-radius: 2px;
}

.progress-label {
  font-size: 0.65rem;
  font-weight: 600;
  color: var(--orange);
  letter-spacing: 0.06em;
  flex-shrink: 0;
}

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.15rem;
  }
  .chip {
    font-size: 0.6rem;
    color: var(--text-secondary);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    padding: 0.25rem 0.65rem;
    border-radius: 4px;
  }

  .social-row {
    display: flex;
    gap: 0.1rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    font-weight: 500;
    color: white;
    text-decoration: none;
    background: var(--bg-elevated);
    border: 1px solid var(--border-muted);
    padding: 0.5rem 1rem;
    border-radius: 5px;
    transition: color 0.2s, border-color 0.2s;
    margin-right: 1rem;
  }
  .social-link:hover {
    color: var(--text-primary);
    border-color: var(--border);
  }
  .social-link svg { opacity: 0.6; flex-shrink: 0; }
  .social-link:hover svg { opacity: 1; }

  /* Nav karty — čistý text, bez číseliek */
  .hero-nav-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    line-height: 15px;
    margin-bottom: 0.5rem;
  }

  .nav-card {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-muted);
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 500;
    color: white;
    text-align: center;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .nav-card:hover {
    color: var(--text-primary);
    border-color: var(--border);
    background: #1C2128;
  }

  /* ── CONTACT BAR ── */
  .contact-bar {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding: 0.5rem 2rem;
    border-top: 1px solid var(--border-muted);
    flex-wrap: wrap;
  }
  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .contact-label {
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .contact-val {
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }
  .contact-val:hover { color: var(--blue); }

  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-left: auto;
    background: var(--blue-dim);
    border: 1px solid rgba(88,166,255,0.25);
    color: var(--blue);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.35rem 0.875rem;
    border-radius: 20px;
  }
  .status-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--blue);
  }

  /* ── RESPONSIVE ── */
 @media (max-width: 860px) {
  .hero {
    display: block;
    height: auto;
    min-height: auto;
  }

  .hero-left {
    border-right: none;
    border-bottom: 1px solid var(--border-muted);
    overflow: visible;
  }

  .hero-right {
    padding: 1.5rem;
    overflow-y: visible;
  }

  .name-block {
    padding: 0 1.5rem;
    gap: 1.25rem;
  }

  .name-row {
    font-size: clamp(2.5rem, 12vw, 5rem);
  }

  .avatar {
    width: 100px;
    height: 100px;
  }

  .bio-text {
    font-size: 0.95rem;
  }

  .info-title {
    font-size: 1.05rem;
  }

  .status-pill {
    margin-left: 0;
  }
}
</style>