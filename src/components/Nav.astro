---
interface Props {
  active?: string;
}
const { active } = Astro.props;
  const base = import.meta.env.BASE_URL;
---
<nav class="nav">
  <a href={import.meta.env.BASE_URL} class="nav-logo">
  Home
</a>

<div class="nav-links">
  <a href={`${base}skusenosti/`} class={`nav-link ${active === "skusenosti" ? "active" : ""}`}>
    Skúsenosti
  </a>
<!--
TODO dokoncit nove stranky 
  <a href={`${base}znalosti/`} class={`nav-link ${active === "znalosti" ? "active" : ""}`}>
    Znalosti
  </a>

  <a href={`${base}vzdelanie/`} class={`nav-link ${active === "vzdelanie" ? "active" : ""}`}>
    Vzdelanie
  </a>
  -->
</div>

</nav>

<style>
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2.5rem;
    border-bottom: 1px solid var(--border-muted);
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--bg);
    backdrop-filter: blur(8px);
  }
  .nav-logo {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-logo:hover { color: var(--text-secondary); }

  .nav-links { display: flex; gap: 0.25rem; }

  .nav-link {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.3rem 0.75rem;
    border-radius: 5px;
    transition: color 0.2s, background 0.2s;
  }
  .nav-link:hover {
    color: var(--text-secondary);
    background: var(--bg-elevated);
  }
  .nav-link.active {
    color: var(--text-primary);
    background: var(--bg-elevated);
    border: 1px solid var(--border-muted);
  }

  @media (max-width: 480px) {
    .nav { padding: 0.875rem 1.25rem; }
    .nav-link { padding: 0.25rem 0.5rem; font-size: 0.7rem; }
  }
</style>
