<style>
  .footer {
    border-top: 1px solid var(--border-muted);
    padding: 1rem 2.5rem;
  }
  .footer-inner {
    max-width: 860px;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .footer-name {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
  }
  .footer-sep {
    color: var(--border);
    font-size: 0.75rem;
  }
  .footer-link {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-link:hover { color: var(--blue); }
  .footer-right {
    margin-left: auto;
    font-size: 0.72rem;
    color: var(--text-muted);
    opacity: 0.5;
  }
