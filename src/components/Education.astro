---
const education = [
  {
    degree: "Inžinierské štúdium — MSc.",
    field: "Informačný manažment",
    school: "Žilinská univerzita — FRI",
    period: "2024 – súčasnosť",
    current: true,
    note: "1. ročník",
  },
  {
    degree: "Bakalárske štúdium — Bc.",
    field: "Informatika a riadenie",
    school: "Žilinská univerzita — FRI",
    period: "2021 – 2024",
    current: false,
    note: "Téma práce: Dátová analytika vo vzdelávacom procese",
  },
  {
    degree: "Gymnázium Šrobárova 1",
    field: null,
    school: "Košice, SR",
    period: "2017 – 2021",
    current: false,
    note: null,
  },
];

const extras = [
  {
    title: "Erasmus Blended Intensive Programme",
    desc: "Medzinárodné tímy, digitálne zručnosti, agilná spolupráca",
  },
  {
    title: "Hackathon — Digitálna infraštruktúra Kysúc",
    desc: "Návrh webovej platformy na správu miestnych zdrojov",
  },
  {
    title: "Rádio X — PR tím",
    desc: "Komunikácia so sponzormi, koordinácia eventov",
  },
  {
    title: "FRI Club — organizačný tím",
    desc: "Príprava podujatí pre študentov fakulty",
  },
];
---

<section class="section" id="vzdelanie">
  <div class="section-inner">
    <div class="section-head">
      <p class="section-label">03</p>
      <h2 class="section-title">Vzdelanie</h2>
    </div>

    <div class="edu-list">
      {education.map((e) => (
        <div class={`edu-row ${e.current ? "edu-row--current" : ""}`}>
          <div class="edu-period">
            <span class={`edu-dot ${e.current ? "edu-dot--current" : ""}`}></span>
            <span>{e.period}</span>
            {e.current && <span class="edu-badge">Prebieha</span>}
          </div>
          <div class="edu-body">
            <p class="edu-degree">{e.degree}</p>
            {e.field && <p class="edu-field">{e.field}</p>}
            <p class="edu-school">{e.school}</p>
            {e.note && <p class="edu-note">{e.note}</p>}
          </div>
        </div>
      ))}
    </div>

    <div class="section-head" style="margin-top: 3rem;">
      <p class="section-label">04</p>
      <h2 class="section-title">Aktivity & projekty</h2>
    </div>

    <div class="extras-grid">
      {extras.map((item) => (
        <div class="extra-card">
          <p class="extra-title">{item.title}</p>
          <p class="extra-desc">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section {
    padding: 3.5rem 2.5rem 4rem;
  }
  .section-inner { max-width: 860px; }

  .section-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 2.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-muted);
  }
  .section-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--text-muted);
  }
  .section-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  /* Education rows */
  .edu-list { display: flex; flex-direction: column; }

  .edu-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border-muted);
    align-items: start;
  }
  .edu-row:last-child { border-bottom: none; }

  .edu-period {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-top: 0.1rem;
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .edu-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--border);
    display: block;
  }
  .edu-dot--current {
    background: var(--orange);
    box-shadow: 0 0 8px rgba(240,136,62,0.35);
  }
  .edu-badge {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--orange);
    background: rgba(240,136,62,0.1);
    border: 1px solid rgba(240,136,62,0.2);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    align-self: flex-start;
  }

  .edu-body {}
  .edu-degree {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.2rem;
  }
  .edu-field {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 0.15rem;
  }
  .edu-school {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.35rem;
  }
  .edu-note {
    font-size: 0.72rem;
    color: var(--text-muted);
    background: var(--bg-elevated);
    border: 1px solid var(--border-muted);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    display: inline-block;
  }

  /* Extras grid */
  .extras-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--border-muted);
    border-radius: 6px;
    overflow: hidden;
  }

  .extra-card {
    padding: 1.1rem 1.25rem;
    border-right: 1px solid var(--border-muted);
    border-bottom: 1px solid var(--border-muted);
    transition: background 0.15s;
  }
  .extra-card:hover { background: var(--bg-elevated); }
  .extra-card:nth-child(even) { border-right: none; }
  .extra-card:nth-last-child(-n+2) { border-bottom: none; }

  .extra-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.2rem;
  }
  .extra-desc {
    font-size: 0.72rem;
    color: var(--text-muted);
    line-height: 1.45;
  }

  @media (max-width: 640px) {
    .edu-row { grid-template-columns: 1fr; gap: 0.6rem; }
    .edu-period { flex-direction: row; align-items: center; flex-wrap: wrap; }
    .extras-grid { grid-template-columns: 1fr; }
    .extra-card:nth-child(even) { border-right: 1px solid var(--border-muted); }
    .extra-card:nth-last-child(-n+2) { border-bottom: 1px solid var(--border-muted); }
    .extra-card:last-child { border-bottom: none; }
  }
</style>
