---
const university = [
  {
    degree: "Gymnázium Šrobárova 1",
    field: null,
    school: "Košice, SR",
    period: "2017 – 2021",
    current: false,
    thesis: null,
    focus: null,
  },
  {
    degree: "Bakalárske štúdium — Bc.",
    field: "Informatika a riadenie",
    school: "Žilinská univerzita — FRI",
    period: "2021 – 2024",
    current: false,
    thesis: "Dátová analytika vo vzdelávacom procese",
    focus: null,
  },
  {
    degree: "Inžinierské štúdium — Ing.",
    field: "Informačný manažment",
    school: "Žilinská univerzita — FRI",
    period: "2024 – súčasnosť",
    current: true,
    thesis: null,
    focus: "",   // doplniť zameranie
  },
];

// Každý pobyt: krajina, univerzita, semester, čo si študoval, čo ti priniesol
const erasmusStays = [
  // { country: "", university: "", semester: "", subject: "", takeaway: "" }
];

// Každý BIP: kde, téma, trvanie, čo si robil
const bip = [
  {
    location: "",           // doplniť
    topic: "Medzinárodné tímy, digitálne zručnosti, agilná spolupráca",
    duration: "",           // doplniť
    role: "",               // doplniť
  },
];

// Kurzy: názov + krátky popis
const courses = [
  { name: "Python",          desc: "" },
  { name: "SQL",             desc: "" },
  { name: "Data Analytics",  desc: "" },
  { name: "Testing",         desc: "" },
  { name: "Git",             desc: "" },
];

// Certifikáty: názov, organizácia, dátum, stručný popis
const certificates = [
  // { name: "", org: "", date: "", desc: "" }
];
---

<div class="page">

  <!-- COL 1 — Univerzita -->
  <div class="col col-uni">
    <div class="section-head">
      <p class="section-label">01</p>
      <h2 class="section-title">Vzdelanie</h2>
    </div>

    <div class="edu-list">
      {university.map((u) => (
        <div class={`edu-row ${u.current ? "edu-row--current" : ""}`}>
          <div class="edu-left">
            <span class={`edu-dot ${u.current ? "edu-dot--current" : ""}`}></span>
            <span class="edu-period">{u.period}</span>
          </div>
          <div class="edu-right">
            <div class="edu-header">
              <h3 class="edu-degree">{u.degree}</h3>
              {u.current && <span class="edu-badge">Prebieha</span>}
            </div>
            {u.field && <p class="edu-field">{u.field}</p>}
            <p class="edu-school">{u.school}</p>
            {u.thesis && (
              <p class="edu-note">📄 {u.thesis}</p>
            )}
            {u.focus && (
              <p class="edu-note">🎯 {u.focus}</p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- COL 2 — Erasmus+ -->
  <div class="col col-erasmus">
    <div class="section-head">
      <p class="section-label">02</p>
      <h2 class="section-title">Erasmus+</h2>
    </div>

    <p class="sub-label">Pobyty</p>
    <div class="stays-list">
      {erasmusStays.length === 0 ? (
        <p class="empty-note">Doplniť neskôr</p>
      ) : (
        erasmusStays.map((s) => (
          <div class="stay-card">
            <div class="stay-header">
              <span class="stay-country">{s.country}</span>
              <span class="stay-semester">{s.semester}</span>
            </div>
            <p class="stay-uni">{s.university}</p>
            {s.subject && <p class="stay-field">📚 {s.subject}</p>}
            {s.takeaway && <p class="stay-takeaway">💡 {s.takeaway}</p>}
          </div>
        ))
      )}
    </div>

    <p class="sub-label" style="margin-top: 1.5rem;">Blended Intensive Programme</p>
    {bip.map((b) => (
      <div class="bip-card">
        <div class="bip-row">
          <span class="bip-key">Miesto</span>
          <span class="bip-val">{b.location || "—"}</span>
        </div>
        <div class="bip-row">
          <span class="bip-key">Téma</span>
          <span class="bip-val">{b.topic || "—"}</span>
        </div>
        <div class="bip-row">
          <span class="bip-key">Trvanie</span>
          <span class="bip-val">{b.duration || "—"}</span>
        </div>
        <div class="bip-row">
          <span class="bip-key">Rola</span>
          <span class="bip-val">{b.role || "—"}</span>
        </div>
      </div>
    ))}
  </div>

  <!-- COL 3 — Kurzy + Certifikáty -->
  <div class="col col-right">

    <div class="right-block">
      <div class="section-head">
        <p class="section-label">03</p>
        <h2 class="section-title">Kurzy</h2>
      </div>
      <ul class="course-list">
        {courses.map((c) => (
          <li class="course-item">
            <span class="course-name">{c.name}</span>
            {c.desc && <span class="course-desc">{c.desc}</span>}
          </li>
        ))}
      </ul>
    </div>

    <div class="right-block">
      <div class="section-head">
        <p class="section-label">04</p>
        <h2 class="section-title">Certifikáty</h2>
      </div>
      {certificates.length === 0 ? (
        <p class="empty-note">Doplniť neskôr</p>
      ) : (
        <ul class="cert-list">
          {certificates.map((c) => (
            <li class="cert-item">
              <div class="cert-header">
                <span class="cert-name">{c.name}</span>
                <span class="cert-date">{c.date}</span>
              </div>
              <p class="cert-org">{c.org}</p>
              {c.desc && <p class="cert-desc">{c.desc}</p>}
            </li>
          ))}
        </ul>
      )}
    </div>

  </div>
</div>

<style>
  /* ── Three-column no-scroll layout ── */
  .page {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    height: 100%;
    overflow: hidden;
  }

  .col {
    overflow-y: auto;
    padding: 2.5rem;
    border-right: 1px solid var(--border-muted);
  }
  .col:last-child { border-right: none; }

  /* Col 3 is flex-col so Kurzy + Certifikáty stack inside */
  .col-right {
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow-y: auto;
  }
  .right-block {
    padding: 2.5rem;
    border-bottom: 1px solid var(--border-muted);
    flex: 1;
  }
  .right-block:last-child { border-bottom: none; }

  /* ── Section / sub headings ── */
  .section-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-muted);
  }
  .section-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    font-family: var(--font-body);
  }
  .section-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .sub-label {
    font-size: 0.63rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  /* ── University rows ── */
  .edu-list { display: flex; flex-direction: column; }

  .edu-row {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 1rem;
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--border-muted);
    align-items: start;
  }
  .edu-row:last-child { border-bottom: none; }

  .edu-left {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding-top: 0.15rem;
  }
  .edu-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--border);
    display: block;
    flex-shrink: 0;
  }
  .edu-dot--current { background: var(--orange); box-shadow: 0 0 8px rgba(240,136,62,0.4); }
  .edu-period {
    font-size: 0.68rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .edu-right { flex: 1; }
  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.2rem;
  }
  .edu-degree {
    font-size: 0.87rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  .edu-badge {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--orange);
    background: rgba(240,136,62,0.1);
    border: 1px solid rgba(240,136,62,0.25);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .edu-field {
    font-size: 0.78rem;
    color: var(--text-secondary);
    margin-bottom: 0.15rem;
  }
  .edu-school {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-bottom: 0.35rem;
  }
  .edu-note {
    font-size: 0.7rem;
    color: var(--text-muted);
    background: var(--bg-elevated);
    border: 1px solid var(--border-muted);
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    display: inline-block;
    margin-top: 0.2rem;
    line-height: 1.45;
  }

  /* ── Erasmus stays ── */
  .stays-list { display: flex; flex-direction: column; gap: 0.75rem; }

  .stay-card {
    padding: 0.9rem 1rem;
    border: 1px solid var(--border-muted);
    border-radius: 6px;
    background: var(--bg-elevated);
  }
  .stay-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.2rem;
  }
  .stay-country {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  .stay-semester {
    font-size: 0.68rem;
    color: var(--text-muted);
  }
  .stay-uni {
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-bottom: 0.35rem;
  }
  .stay-field,
  .stay-takeaway {
    font-size: 0.72rem;
    color: var(--text-muted);
    line-height: 1.45;
    margin-top: 0.2rem;
  }

  /* ── BIP card ── */
  .bip-card {
    border: 1px solid var(--border-muted);
    border-left: 2px solid var(--orange);
    border-radius: 6px;
    background: var(--bg-elevated);
    overflow: hidden;
  }
  .bip-row {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 0.75rem;
    padding: 0.5rem 0.9rem;
    border-bottom: 1px solid var(--border-muted);
    align-items: baseline;
  }
  .bip-row:last-child { border-bottom: none; }
  .bip-key {
    font-size: 0.63rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    text-transform: uppercase;
  }
  .bip-val {
    font-size: 0.75rem;
    color: var(--text-secondary);
    line-height: 1.45;
  }

  /* ── Courses ── */
  .course-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .course-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--border-muted);
  }
  .course-item:last-child { border-bottom: none; }
  .course-name {
    font-size: 0.83rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  .course-desc {
    font-size: 0.72rem;
    color: var(--text-muted);
    line-height: 1.45;
  }

  /* ── Certificates ── */
  .cert-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .cert-item {
    padding: 0.85rem 1rem;
    border: 1px solid var(--border-muted);
    border-radius: 6px;
    background: var(--bg-elevated);
  }
  .cert-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.15rem;
  }
  .cert-name {
    font-size: 0.83rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  .cert-date {
    font-size: 0.68rem;
    color: var(--text-muted);
  }
  .cert-org {
    font-size: 0.72rem;
    color: var(--text-secondary);
    margin-bottom: 0.2rem;
  }
  .cert-desc {
    font-size: 0.7rem;
    color: var(--text-muted);
    line-height: 1.45;
  }

  /* ── Empty state ── */
  .empty-note {
    font-size: 0.72rem;
    color: var(--text-muted);
    font-style: italic;
  }

  /* ── Mobile: single column, scrollable ── */
  @media (max-width: 900px) {
    .page {
      grid-template-columns: 1fr;
      height: auto;
      overflow: visible;
    }
    .col {
      border-right: none;
      border-bottom: 1px solid var(--border-muted);
      overflow-y: visible;
    }
    .col-right {
      padding: 0;
      overflow-y: visible;
    }
    .col:last-child { border-bottom: none; }
    .edu-row { grid-template-columns: 1fr; gap: 0.5rem; }
    .edu-left { flex-direction: row; align-items: center; gap: 0.75rem; }
  }
</style>