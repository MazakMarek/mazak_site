---
const education = [
  {
    degree: "Inžinierské štúdium (MSc.)",
    field: "Informačný manažment",
    school: "Žilinská univerzita — FRI",
    period: "2024 – súčasnosť",
    current: true,
    note: "1. ročník",
  },
  {
    degree: "Bakalárske štúdium (Bc.)",
    field: "Informatika a riadenie",
    school: "Žilinská univerzita — FRI",
    period: "2021 – 2024",
    current: false,
    note: "Téma práce: Dátová analytika vo vzdelávacom procese",
  },
  {
    degree: "Stredná škola",
    field: "Gymnázium Šrobárova 1",
    school: "Košice, SR",
    period: "2017 – 2021",
    current: false,
    note: null,
  },
];

const extras = [
  {
    icon: "🌍",
    title: "Erasmus Blended Intensive Programme",
    desc: "Medzinárodné tímy, digitálne zručnosti a agilná spolupráca",
  },
  {
    icon: "💻",
    title: "Hackathon — Digitálna infraštruktúra Kysúc",
    desc: "Návrh webovej platformy na správu miestnych zdrojov a digitalizáciu služieb",
  },
  {
    icon: "📡",
    title: "Rádio X — PR tím",
    desc: "Komunikácia so sponzormi, koordinácia eventov",
  },
  {
    icon: "🎓",
    title: "FRI Club — člen organizačného tímu",
    desc: "Príprava podujatí pre študentov Fakulty riadenia a informatiky",
  },
];
---

<section class="section">
  <div class="section-inner">
    <h2 class="section-title">
      <span class="title-label">Vzdelanie</span>
    </h2>

    <div class="edu-list">
      {education.map((edu) => (
        <div class={`edu-card ${edu.current ? 'edu-card--current' : ''}`}>
          <div class="edu-left">
            <p class="edu-period">{edu.period}</p>
            {edu.current && <span class="badge-current">aktívne</span>}
          </div>
          <div class="edu-right">
            <h3 class="edu-degree">{edu.degree}</h3>
            <p class="edu-field">{edu.field}</p>
            <p class="edu-school">{edu.school}</p>
            {edu.note && <p class="edu-note">{edu.note}</p>}
          </div>
        </div>
      ))}
    </div>

    <h2 class="section-title" style="margin-top: 3.5rem;">
      <span class="title-label">Aktivity & projekty</span>
    </h2>

    <div class="extras-grid">
      {extras.map((item) => (
        <div class="extra-card">
          <span class="extra-icon">{item.icon}</span>
          <div>
            <p class="extra-title">{item.title}</p>
            <p class="extra-desc">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section {
    padding: 4rem 2rem;
    border-bottom: 1px solid var(--border);
  }

  .section-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 2.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .title-label {
    white-space: nowrap;
  }

  /* Education */
  .edu-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .edu-card {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    align-items: start;
    transition: border-color 0.2s;
  }

  .edu-card--current {
    border-color: var(--accent);
    background: #f7fefb;
  }

  .edu-card:hover {
    border-color: var(--accent);
  }

  .edu-left {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    align-items: flex-start;
    padding-top: 0.15rem;
  }

  .edu-period {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--muted);
    font-family: var(--font-display);
  }

  .badge-current {
    background: var(--accent-dim);
    border: 1px solid var(--accent);
    color: var(--accent);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border-radius: 20px;
  }

  .edu-degree {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 0.15rem;
  }

  .edu-field {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--dark-mid);
    margin-bottom: 0.1rem;
  }

  .edu-school {
    font-size: 0.82rem;
    color: var(--muted);
    margin-bottom: 0.4rem;
  }

  .edu-note {
    font-size: 0.82rem;
    color: var(--muted);
    font-style: italic;
    background: var(--bg);
    padding: 0.3rem 0.6rem;
    border-radius: 4px;
    display: inline-block;
  }

  /* Extras */
  .extras-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .extra-card {
    display: flex;
    gap: 0.85rem;
    padding: 1rem 1.1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: border-color 0.2s;
  }

  .extra-card:hover {
    border-color: var(--accent);
  }

  .extra-icon {
    font-size: 1.3rem;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 0.1rem;
  }

  .extra-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 0.2rem;
  }

  .extra-desc {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.4;
  }

  @media (max-width: 640px) {
    .edu-card {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    .extras-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
