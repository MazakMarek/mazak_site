<style>
.section {
    border-bottom: 1px solid var(--border-muted);
    padding: 3.5rem 2.5rem;
  }
  .section-inner { max-width: 860px; }

  .section-head {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-muted);
  }
.section-note {
  font-size: 0.8rem;
  color: var(--text-muted);
  margin: -1.5rem auto 2rem;
  font-style: italic;
  text-align: center;
  width: 100%;
}
</style>